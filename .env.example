# Copy to .env and fill in real values. Never commit .env.

# --- Database ---------------------------------------------------------------
# For `docker compose up`: the `db` service name resolves inside the compose
# network. For local (non-docker) dev, point this at your own Postgres.
DATABASE_URL=postgresql://postgres:postgres@db:5432/starwood_om_map

# --- Anthropic --------------------------------------------------------------
ANTHROPIC_API_KEY=

# --- Google Maps ------------------------------------------------------------
# Two keys because server-side (geocoding) and client-side (Street View in the
# browser) need different restriction types:
#   - GOOGLE_MAPS_API_KEY: IP-restricted to the container's egress IP,
#     API-restricted to Geocoding API. Used server-side by geocoder.py.
#   - GOOGLE_STREETVIEW_API_KEY: HTTP-referrer-restricted to the app's
#     domain, API-restricted to Street View Static API. Embedded in popup
#     <img> tags, so it is visible to any user of the app.
# If GOOGLE_STREETVIEW_API_KEY is unset, Street View falls back to
# GOOGLE_MAPS_API_KEY so the feature keeps working before the split.
GOOGLE_MAPS_API_KEY=
GOOGLE_STREETVIEW_API_KEY=

# --- Azure Blob Storage -----------------------------------------------------
# Auth uses DefaultAzureCredential:
#   - In prod (on Azure infra), leave AZURE_CLIENT_* unset; managed identity
#     takes over automatically.
#   - For local dev, create a service principal with Storage Blob Data
#     Contributor on the container and set the three AZURE_CLIENT_* values
#     below. Mounting the host `az login` cache does not work from Linux
#     containers on Windows (DPAPI-encrypted tokens), so we use env-based
#     auth instead.
AZURE_STORAGE_ACCOUNT=
AZURE_BLOB_CONTAINER=om-pdfs
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
