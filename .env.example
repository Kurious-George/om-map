# Copy to .env and fill in real values. Never commit .env.

# --- Database ---------------------------------------------------------------
# For `docker compose up`: the `db` service name resolves inside the compose
# network. For local (non-docker) dev, point this at your own Postgres.
DATABASE_URL=postgresql://postgres:postgres@db:5432/starwood_om_map

# --- Anthropic --------------------------------------------------------------
ANTHROPIC_API_KEY=

# --- Google Maps Geocoding --------------------------------------------------
GOOGLE_MAPS_API_KEY=

# --- Azure Blob Storage -----------------------------------------------------
# Auth uses DefaultAzureCredential:
#   - In prod (on Azure infra), leave AZURE_CLIENT_* unset; managed identity
#     takes over automatically.
#   - For local dev, create a service principal with Storage Blob Data
#     Contributor on the container and set the three AZURE_CLIENT_* values
#     below. Mounting the host `az login` cache does not work from Linux
#     containers on Windows (DPAPI-encrypted tokens), so we use env-based
#     auth instead.
AZURE_STORAGE_ACCOUNT=
AZURE_BLOB_CONTAINER=om-pdfs
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# --- App ---------------------------------------------------------------------
# Comma-separated list of employees shown in the sidebar user picker.
# Temporary stand-in for real auth; will be replaced with a reverse-proxy
# header lookup once IT confirms the proxy setup.
APP_USERS="Jane Doe,John Smith"
